{
  "name": "@gatoway/core",
  "version": "0.1.0",
  "private": true,
  "description": "Gatoway core: the application-agnostic communications hub between an Elgato Stream Deck and application plugins.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "manual:tcp-client": "tsx test/manual/tcpTestClient.ts",
    "manual:ws-client": "tsx test/manual/wsTestClient.ts"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-roll": "^4.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
